DATABASE_URL="database-url"
PORT=3001
BACKEND_URL="http://localhost:3001"
# Local dev may use localhost. Production must be the public HTTPS browser origin.
FRONTEND_URL="http://localhost:3000"

# Global HTTP rate limiting (@nestjs/throttler). Các auth endpoint nhạy cảm
# như login/register/forgot-password/reset-password còn có limit chặt hơn trong code.
THROTTLE_DEFAULT_LIMIT=300
THROTTLE_DEFAULT_TTL_MS=60000
THROTTLE_DEFAULT_BLOCK_DURATION_MS=60000

# Nếu deploy sau reverse proxy (Nginx/Render/Fly/Heroku), set TRUST_PROXY=1
# hoặc giá trị phù hợp để throttler nhìn thấy đúng client IP. Local dev để false.
TRUST_PROXY=false

# Dashboard response cache trong bảng dashboard_cache của PostgreSQL.
# Đây là TTL cache phía server cho các read endpoint nặng của admin dashboard.
DASHBOARD_CACHE_DEFAULT_TTL_SECONDS=60

# Backend auth identity cache (in-memory, per-process) để giảm query lặp
# bảng users/staff_info ở JwtStrategy, RolesGuard và /auth/profile.
AUTH_IDENTITY_CACHE_TTL_MS=5000
AUTH_IDENTITY_CACHE_MAX_ENTRIES=2000

# Bắt buộc để gửi email xác thực, quên mật khẩu và biên nhận nạp ví SePay cho phụ huynh.
# ADMIN_EMAIL nhận link duyệt yêu cầu nạp thẳng ví học sinh từ CSKH/kế toán/trợ lí.
# ADMIN_EMAIL phải là mailbox thật; backend reject placeholder như admin@example.com/localhost.
# Nếu thiếu ADMIN_EMAIL hoặc SMTP fail, backend không lưu yêu cầu nạp thẳng pending.
# Nếu không cấu hình SMTP, auth mail trả lỗi 503; webhook SePay vẫn ack và chỉ log lỗi gửi receipt.
ADMIN_EMAIL=""
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="smtp-user"
# Gmail: dùng App Password 16 ký tự, không dùng mật khẩu đăng nhập Google thường.
# Có thể dán dạng "abcd efgh ijkl mnop"; backend sẽ bỏ khoảng trắng khi SMTP_HOST là Gmail.
SMTP_PASS="smtp-pass"
SMTP_SECURE=false
MAIL_FROM="no-reply@example.com"

# Biên lai email (React Email) + PDF đính kèm (Puppeteer + Chromium).
# Docker image API đã cài Chromium và set CHROMIUM_PATH=/usr/bin/chromium.
# macOS local: ví dụ `/Applications/Google Chrome.app/Contents/MacOS/Google Chrome`
# hoặc đường dẫn Chromium tương đương. Thiếu/không chạy được Chromium thì mail vẫn gửi HTML, không có file PDF.
CHROMIUM_PATH=""

# Tuỳ chọn — ghi đè hiển thị trên biên lai (mặc định lấy từ SEPAY_TRANSFER_* nếu có).
# RECEIPT_DOCUMENT_TITLE="Biên lai xác nhận học phí"
# RECEIPT_RECEIVER_NAME=""
# RECEIPT_RECEIVER_BANK_NAME=""
# RECEIPT_RECEIVER_BANK_ACCOUNT=""

# Google OAuth (đăng nhập bằng Google). Redirect URI trong Google Console: BACKEND_URL/auth/google/callback
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/auth/google/callback"

# Supabase Storage (avatar + CCCD upload)
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

JWT_EMAIL_VERIFY_SECRET="a"
JWT_FORGOT_PASSWORD_SECRET="a"
JWT_ACCESS_SECRET="a"
JWT_REFRESH_SECRET="a"

# Google Calendar Service Account Configuration
# Option 1: Base64 encoded service account JSON key (preferred for deployment)
# Get this from Google Cloud Console: IAM & Admin > Service Accounts > Create Key (JSON)
# Then: base64 -i key.json | pbcopy (or copy output)
GOOGLE_SERVICE_ACCOUNT_KEY="base64-encoded-service-account-json"
# Option 2: Direct path to service account JSON file (for local development)
# GOOGLE_SERVICE_ACCOUNT_JSON_PATH="/path/to/service-account-key.json"
# Calendar ID to use (optional, defaults to service account's primary calendar)
# To find your calendar ID: Google Calendar Settings > Calendar ID
GOOGLE_CALENDAR_ID="your-calendar-id@group.calendar.google.com"
# Time zone for calendar events (defaults to Asia/Ho_Chi_Minh)
GOOGLE_TIME_ZONE="Asia/Ho_Chi_Minh"
# Required for creating fixed tutor Meet links with staff co-host/admit rights.
# Generate this refresh token from the admin Google account with scopes:
# https://www.googleapis.com/auth/calendar
# https://www.googleapis.com/auth/meetings.space.settings
# GOOGLE_OAUTH_CLIENT_ID="your-calendar-oauth-client-id.apps.googleusercontent.com"
# GOOGLE_OAUTH_CLIENT_SECRET="your-calendar-oauth-client-secret"
# GOOGLE_REFRESH_TOKEN="your-admin-refresh-token"

# SePay — nạp ví học sinh.
# Mode mặc định `va_order`: tạo VA order qua SePay UserAPI v2 (SePay docs hỗ trợ BIDV/Sacombank).
# Mode `bank_transfer`: tạo QR chuyển khoản thường (phù hợp ngân hàng không hỗ trợ VA orders như MBBank);
# webhook SePay vẫn reconcile theo nội dung chuyển khoản chứa mã đơn.
SEPAY_TOPUP_MODE="va_order"

# Mode va_order: lấy token & bank account xid từ bảng điều khiển SePay.
# Khi thiếu token hoặc SEPAY_BANK_ACCOUNT_XID ở mode va_order, các endpoint tạo QR nạp ví trả 503.
SEPAY_API_ACCESS_TOKEN=""
SEPAY_BANK_ACCOUNT_XID=""
# Tuỳ chọn: https://userapi.sepay.vn (production) hoặc URL sandbox nếu SePay cấp.
# SEPAY_USERAPI_BASE_URL="https://userapi.sepay.vn"
# Bắt buộc với một số ngân hàng (vd. Sacombank) — xem tài liệu SePay VA prefix.
# SEPAY_VA_PREFIX=""
# Thời sống VA/giữ đơn (giây), mặc định 900 khi không set.
# SEPAY_ORDER_DURATION_SECONDS=900

# Mode bank_transfer: thông tin tài khoản nhận tiền để tạo VietQR quick link.
# Ví dụ MBBank: BIN 970422, số tài khoản 722732006.
# VietinBank cá nhân/hộ kinh doanh theo hướng dẫn SePay cần prefix SEVQR ở đầu nội dung CK.
# SEPAY_TRANSFER_BANK_BIN="970422"
# SEPAY_TRANSFER_ACCOUNT_NUMBER="722732006"
# SEPAY_TRANSFER_ACCOUNT_NAME="VU MINH PHUONG"
# SEPAY_TRANSFER_BANK_NAME="MBBank"
# SEPAY_TRANSFER_QR_TEMPLATE="compact2"
# Có thể đổi sang SePay QR helper: "https://qr.sepay.vn/img" (dùng acc/bank/des).
# SEPAY_VIETQR_IMAGE_BASE_URL="https://img.vietqr.io/image"
SEPAY_TRANSFER_NOTE_PREFIX=""

# Secret cấu hình trong SePay Webhooks/IPN.
# Backend ưu tiên verify X-SePay-Signature + X-SePay-Timestamp bằng HMAC-SHA256:
#   HMAC(secret, UTF-8(`${timestamp}.`) + exact raw body bytes) -> X-SePay-Signature: sha256=<hex>
# Body dùng để ký là raw body đúng byte SePay gửi, không phải body JSON đã parse/serialize lại.
# Timestamp lệch quá tolerance bị từ chối để giảm replay. Dùng 0 chỉ cho smoke test thủ công khi cần replay payload cũ.
# X-Secret-Key cũ chỉ được chấp nhận khi bật SEPAY_WEBHOOK_ALLOW_LEGACY_SECRET_KEY=1. Thiếu secret thì POST /webhook/sepay trả 503.
# Webhook hợp lệ trả {"success":true} sau khi reconcile/ghi ví.
SEPAY_WEBHOOK_SECRET=""
SEPAY_WEBHOOK_SIGNATURE_TOLERANCE_SECONDS=300
SEPAY_WEBHOOK_ALLOW_LEGACY_SECRET_KEY=0

# Landing CMS integration (unicorns-edu-landing server-to-server sync).
# Shared secret sent by the landing admin as header X-API-Key on
# GET /staff/landing-profiles and GET /student/landing-profiles.
# Must match EDUWEB5_API_KEY on the landing admin deployment.
# Generate: openssl rand -hex 32
# Docs: docs/api/landing-integration.md
LANDING_API_KEY=""
