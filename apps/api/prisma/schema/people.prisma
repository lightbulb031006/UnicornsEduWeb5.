/// Lookup by `user_id` uses unique index `staff_info_user_id_key`. PostgreSQL definition adds
/// `INCLUDE (id, roles)` for index-only scans (auth/session); Prisma has no INCLUDE syntax — see
/// migration `20260506140000_staff_info_user_id_covering_index`.
model StaffInfo {
  id                                  String                               @id
  cccdNumber                          String?                              @unique @map("cccd_number")
  cccdIssuedDate                      DateTime?                            @map("cccd_issued_date") @db.Date
  cccdIssuedPlace                     String?                              @map("cccd_issued_place")
  ethnicity                           String?
  gender                              Gender?
  currentAddress                      String?                              @map("current_address")
  birthDate                           DateTime?                            @map("birth_date") @db.Date
  university                          String?
  highSchool                          String?                              @map("high_school")
  specialization                      String?
  bankAccount                         String?                              @map("bank_account")
  bankQrLink                          String?                              @map("bank_qr_link")
  googleMeetLink                      String?                              @map("google_meet_link")
  status                              StaffStatus                          @default(active)
  createdAt                           DateTime                             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                           DateTime                             @updatedAt @map("updated_at") @db.Timestamptz(6)
  userId                              String?                              @map("user_id")
  roles                               StaffRole[]                          @default([])
  personalAchievementLink             String?                              @map("personal_achievement_link")
  customerCareManagedByStaffId        String?                              @map("customer_care_managed_by_staff_id")
  assistantStudentSession             Attendance[]                         @relation("AttendanceAssistant")
  customerCareStudentSession          Attendance[]                         @relation("AttendanceCustomerCare")
  bonuses                             Bonus[]
  classSurveys                        ClassSurvey[]
  classTeachers                       ClassTeacher[]
  customerCareServices                CustomerCareService[]
  extraAllowances                     ExtraAllowance[]
  lessonOutputs                       LessonOutput[]
  makeupScheduleEvents                MakeupScheduleEvent[]
  staffTaxDeductionOverrides          StaffTaxDeductionOverride[]
  tasksCreated                        LessonTask[]
  sessions                            Session[]
  customerCareManagedBy               StaffInfo?                           @relation("AssistantManagesCustomerCare", fields: [customerCareManagedByStaffId], references: [id])
  managedCustomerCareStaff            StaffInfo[]                          @relation("AssistantManagesCustomerCare")
  user                                User?                                @relation(fields: [userId], references: [id])
  staffLessonTasks                    StaffLessonTask[]
  monthlyStats                        StaffMonthlyStat[]

  @@unique([userId], map: "staff_info_user_id_key")
  @@index([customerCareManagedByStaffId])
  @@map("staff_info")
}

model StudentInfo {
  id                   String                            @id
  fullName             String                            @map("full_name")
  email                String?
  school               String?
  province             String?
  birthYear            Int?                              @map("birth_year")
  parentName           String?                           @map("parent_name")
  parentPhone          String?                           @map("parent_phone")
  parentEmail          String?                           @map("parent_email")
  status               StudentStatus                     @default(active)
  gender               Gender                            @default(male)
  goal                 String?
  dropOutDate          DateTime?                         @map("drop_out_date") @db.Date
  createdAt            DateTime                          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime                          @updatedAt @map("updated_at") @db.Timestamptz(6)
  userId               String?                           @unique @map("user_id")
  accountBalance       Int?                              @default(0) @map("account_balance")
  attendanceRecords    Attendance[]
  customerCareServices CustomerCareService?
  examSchedules        StudentExamSchedule[]
  studentClasses       StudentClass[]
  user                 User?                             @relation(fields: [userId], references: [id])
  walletTransactions   WalletTransactionsHistory[]
  sepayWalletOrders    StudentWalletSepayOrder[]
  directTopUpRequests  StudentWalletDirectTopUpRequest[]

  @@map("student_info")
}

model StudentExamSchedule {
  id        String      @id @default(uuid()) @db.Text
  studentId String      @map("student_id") @db.Text
  examDate  DateTime    @map("exam_date") @db.Date
  note      String?
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  student   StudentInfo @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([examDate])
  @@map("student_exam_schedules")
}
